# ============================================================
#  Copiez ce fichier en ".env.local" et renseignez les variables
# ============================================================

# URL de votre site WordPress (sans slash final)
VITE_WP_URL=https://your-wordpress.com

# Optionnel — afficher la page d'attente tant que cette date n'est pas atteinte
# Format ISO local : YYYY-MM-DDTHH:mm (fuseau local du navigateur)
# VITE_COMING_SOON_UNTIL=2026-06-01T12:00
